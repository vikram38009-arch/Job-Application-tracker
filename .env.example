# GEMINI_API_KEY: Required for Gemini AI API calls.
# Configure this with your Gemini API key from Google AI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this application is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PostgreSQL Database Configuration
# These are used to connect to your real remote or local PostgreSQL database.
DATABASE_URL="postgresql://user:password@hostname:5432/dbname"
POSTGRES_DB="jobtracker"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="mypassword"
POSTGRES_HOST="localhost"
POSTGRES_PORT="5432"

# OpenAI API key for Job Smart Analyst
OPENAI_API_KEY=

